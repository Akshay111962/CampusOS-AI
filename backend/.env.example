# Database Connection URL (e.g., postgresql+asyncpg://postgres:postgres@localhost:5432/campusos)
DATABASE_URL=

# URL for Redis instance used by Celery background tasks (e.g., redis://localhost:6379/0)
REDIS_URL=

# Secret key used for signing JWT tokens
JWT_SECRET_KEY=

# Fernet symmetric encryption key for encrypting Gmail tokens and other credentials
FERNET_KEY=

# Anthropic Claude API key used for event parsing and extraction
ANTHROPIC_API_KEY=

# Allowed email domain for student signups (e.g., @dau.ac.in)
ALLOWED_EMAIL_DOMAIN=

# SMTP server host for sending transaction and alert emails
SMTP_HOST=

# SMTP server port (e.g., 587 or 1025)
SMTP_PORT=

# SMTP authentication username
SMTP_USER=

# SMTP authentication password
SMTP_PASSWORD=

# Sender email address used by the system
SMTP_FROM=

# Twilio Account SID for sending WhatsApp notifications
TWILIO_ACCOUNT_SID=

# Twilio Auth Token for Twilio API authentication
TWILIO_AUTH_TOKEN=

# Twilio WhatsApp number to send notifications from (e.g., whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=

# Google OAuth Client ID for Gmail integration
GOOGLE_CLIENT_ID=

# Google OAuth Client Secret for Gmail integration
GOOGLE_CLIENT_SECRET=
